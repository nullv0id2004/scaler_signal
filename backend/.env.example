# Backend environment configuration.
# Copy to `.env` in `backend/` and adjust as needed. Values below are the defaults
# baked into app/core/config.py:Settings, shown explicitly for clarity.

# SQLAlchemy async URL (SQLite + aiosqlite driver, WAL mode enabled at startup).
DATABASE_URL=sqlite+aiosqlite:///./signal.db

# JWT signing secret (python-jose). CHANGE THIS for any non-local deployment.
JWT_SECRET=dev-secret-change-me

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# Access token lifetime, in minutes. Default is 7 days (60 * 24 * 7).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Allowed CORS origins for the frontend, as a JSON array (pydantic-settings
# parses list-typed env vars as JSON).
CORS_ORIGINS=["http://localhost:3000"]

# --- OTP lifecycle ---
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_SECONDS=30
OTP_LENGTH=6

# --- SMS sending ---
# "console" logs/prints the code (no paid provider needed) | "twilio" (stub, not wired up).
SMS_PROVIDER=console
# When true (with the console provider), POST /api/auth/request-otp echoes the
# generated code back in the response body (`dev_code`) so the demo works
# without a real SMS provider.
OTP_DEV_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
